# =======================================
# Fazsee Store - Root .gitignore
# =======================================

# Environment variables (CRITICAL - contains secrets)
.env
.env.*
!.env.example

# Dependencies
node_modules/

# Build outputs
dist/
build/
.cache/

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.sublime-workspace
*.sw?

# Logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
